# ============================================================
# AI-Ops Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=mysql+aiomysql://root:000000@192.168.100.5:30306/ai_ops

# JWT
JWT_SECRET_KEY=change-me-in-production-use-random-string

# LLM (DeepSeek or OpenAI-compatible)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# Embedding (Ollama local)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_API_KEY=ollama

# K8s Master (SSH)
K8S_MASTER_HOST=192.168.100.5
K8S_MASTER_PORT=22
K8S_MASTER_USER=root
K8S_MASTER_PASSWORD=your-password

# Prometheus (optional)
PROMETHEUS_URL=

# DingTalk Notification
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# Performance
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
LLM_REQUEST_TIMEOUT=120
TOOL_EXEC_TIMEOUT=45
CIRCUIT_BREAKER_FAILURES=5
MAX_COMMAND_LENGTH=2000
